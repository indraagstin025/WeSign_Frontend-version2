# Override API base URL untuk seluruh aplikasi.
#
# Jika VITE_API_URL TIDAK di-set:
#   - Saat dijalankan di localhost (dev server)         -> otomatis pakai LOCAL
#   - Saat di-deploy ke domain lain (Vercel, dsb.)      -> otomatis pakai PRODUCTION
#
# Set salah satu di bawah untuk override paksa:

# --- LOCAL (backend dev) ---
# VITE_API_URL=http://localhost:3000/api

# --- PRODUCTION (Railway) ---
# VITE_API_URL=https://wesign-backend-production.up.railway.app/api
